// Data model for accounts, contacts, and transfer history.
// File contents never touch the server in P2P mode — `transfers` stores metadata
// only, which keeps the privacy story simple (nothing sensitive to leak or purge).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  displayName  String   @map("display_name")
  // email and telegramId are both nullable: a user may link only one method.
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  telegramId   BigInt?  @unique @map("telegram_id")
  // UI accent preset key (e.g. "green", "cobalt"), follows the user across devices.
  accentPreference String? @map("accent_preference")
  createdAt    DateTime @default(now()) @map("created_at")

  contactsOwned     Contact[]  @relation("ContactOwner")
  contactsReceived  Contact[]  @relation("ContactTarget")
  sentTransfers     Transfer[] @relation("TransferSender")
  receivedTransfers Transfer[] @relation("TransferRecipient")
  devices           Device[]

  @@map("users")
}

// A linked device (paired via code/QR instead of a password). Sessions issued to
// a device carry its id in the JWT so revoking it (setting revokedAt) rejects
// that device on its very next request, not just at its next login.
model Device {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  label      String
  platform   String?
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("devices")
}

enum PairingStatus {
  pending
  approved
  expired
}

// A short-lived, single-use pairing code. Not tied to a user until an already-
// authenticated device approves it — that's the point: the requesting device
// doesn't know whose account it will join yet.
model PairingRequest {
  id                String        @id @default(cuid())
  code              String        @unique
  status            PairingStatus @default(pending)
  requestedPlatform String?       @map("requested_platform")
  requestedLabel    String?       @map("requested_label")
  // Set once approved: the device row created for the requester, so the polling
  // requester can be handed a session for it exactly once.
  approvedDeviceId  String?       @map("approved_device_id")
  claimedAt         DateTime?     @map("claimed_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  expiresAt         DateTime      @map("expires_at")

  @@map("pairing_requests")
}

// A directed edge owner -> contact. Mutual acceptance is modelled by inserting
// the reverse edge when the other side accepts, so a user can't be silently
// added to someone's contacts without their own matching edge existing.
model Contact {
  id            String   @id @default(cuid())
  ownerUserId   String   @map("owner_user_id")
  contactUserId String   @map("contact_user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  owner   User @relation("ContactOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  contact User @relation("ContactTarget", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, contactUserId])
  @@index([contactUserId])
  @@map("contacts")
}

enum TransferStatus {
  completed
  failed
}

model Transfer {
  id              String         @id @default(cuid())
  senderUserId    String         @map("sender_user_id")
  // recipient may be null for a one-off transfer to a non-account peer.
  recipientUserId String?        @map("recipient_user_id")
  fileName        String         @map("file_name")
  fileSize        BigInt         @map("file_size")
  status          TransferStatus
  // Human-readable reason, set when status is `failed`.
  failureReason   String?        @map("failure_reason")
  createdAt       DateTime       @default(now()) @map("created_at")

  sender    User  @relation("TransferSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipient User? @relation("TransferRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([senderUserId, createdAt])
  @@index([recipientUserId, createdAt])
  @@map("transfers")
}
