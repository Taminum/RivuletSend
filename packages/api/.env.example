# Copy to .env and adjust. Local dev defaults match docker-compose.yml.

NODE_ENV=development
PORT=8081

# Postgres connection. The default points at the docker-compose Postgres.
DATABASE_URL=postgresql://p2p:p2p@localhost:5432/p2p?schema=public

# Secret for signing session JWTs. MUST be a strong random value in production.
JWT_SECRET=dev-insecure-secret-change-me

# Web app origin, for CORS with credentials.
WEB_ORIGIN=http://localhost:5173

# Set true when serving over HTTPS (adds Secure flag to the auth cookie).
COOKIE_SECURE=false

# Telegram bot token — required only to verify Telegram Login Widget sign-ins.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Shared secret the signaling server uses for internal calls (mutual-contact
# check). MUST match signaling's INTERNAL_SECRET.
INTERNAL_API_SECRET=dev-internal-secret

# --- ICE / TURN, served to clients by GET /turn-credentials ---

STUN_URL=stun:stun.l.google.com:19302

# TURN relay URLs handed to clients, comma-separated.
# TURN_URLS=turn:send.example.com:3478?transport=udp,turn:send.example.com:3478?transport=tcp

# Must equal coturn's --static-auth-secret. The API derives an expiring
# credential from it per request, so no fixed relay password is ever shipped to
# a browser. Without both TURN_SECRET and TURN_URLS the endpoint returns STUN
# only. deploy/install.sh sets these up automatically.
# TURN_SECRET=

# Lifetime of a minted TURN credential, in seconds (default 12h).
# TURN_TTL=43200
