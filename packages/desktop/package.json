{
  "name": "@p2p/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "RivuletSend — peer-to-peer file transfer",
  "author": "RivuletSend",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.rivuletsend.app",
    "productName": "RivuletSend",
    "files": ["main.js", "preload.js"],
    "win": {
      "target": "nsis"
    },
    "portable": {
      "artifactName": "RivuletSend-${version}-portable.exe"
    }
  }
}
