# Copy to .env (or .env.local) and adjust for your deployment.

# Base URL of the accounts API.
VITE_API_URL=http://localhost:8081

# WebSocket URL of the signaling server.
# Local dev default is ws://localhost:8080. In production use wss:// (TLS).
VITE_SIGNALING_URL=ws://localhost:8080

# Username of your Telegram bot (without @). Enables the Telegram Login Widget.
# The bot's domain must be registered via @BotFather /setdomain for it to render.
# Leave unset to hide the Telegram sign-in option.
# VITE_TELEGRAM_BOT_USERNAME=your_bot

# STUN server for NAT traversal. The Google public STUN works for most peers.
VITE_STUN_URL=stun:stun.l.google.com:19302

# TURN relay — REQUIRED for peers behind symmetric NATs (mobile carriers, some
# corporate wifi) where direct P2P can't be established. Leave blank to skip.
# Point at a coturn instance or a hosted TURN provider. Multiple URLs may be
# given comma-separated (e.g. udp, tcp and tls variants).
# VITE_TURN_URL=turn:turn.example.com:3478,turns:turn.example.com:5349
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
