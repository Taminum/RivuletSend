# Copy to .env for local dev. Defaults already match the API's dev defaults,
# so the anonymous flow works with no .env at all; these matter once the
# authenticated contact-based flow is used.

PORT=8080

# Must match the API's JWT_SECRET so presence tokens verify.
JWT_SECRET=dev-insecure-secret-change-me

# Must match the API's INTERNAL_API_SECRET for mutual-contact authorization.
INTERNAL_SECRET=dev-internal-secret

# Base URL of the API service (for internal authz calls).
API_INTERNAL_URL=http://localhost:8081
